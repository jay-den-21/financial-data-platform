# Copy to .env and fill in local secrets. Do not commit real values.
FDP_ENV=local
FDP_DB_DRIVER=mysql+pymysql
# Optional: set FDP_DATABASE_URL instead of the individual FDP_DB_* values.
FDP_DATABASE_URL=
FDP_DB_HOST=localhost
FDP_DB_PORT=3306
FDP_DB_USER=
FDP_DB_PASSWORD=
FDP_DB_NAME=
EODHD_API_KEY=
